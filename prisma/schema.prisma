generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  passwordHash  String?
  role          String   @default("user")
  jlptLevel     String   @default("N5")
  totalPoints   Int      @default(0)
  streakCount   Int      @default(0)
  lastStudyDate DateTime?
  userData      Json     @default("{}")
  syncedAt      DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  progress     UserProgress[]
  quizAttempts QuizAttempt[]
  bookmarks    Bookmark[]
}

model KanaCharacter {
  id          String @id @default(cuid())
  character   String
  romaji      String
  type        String // hiragana, katakana
  category    String // gojuon, dakuon, handakuon, yoon
  row         String // a, ka, sa, ta, na, ha, ma, ya, ra, wa
  orderIndex  Int
  strokeCount Int    @default(1)
}

model Word {
  id              String @id @default(cuid())
  word            String
  reading         String
  meaning         String
  jlptLevel       String // N5, N4, N3, N2, N1
  partOfSpeech    String
  exampleSentence String?
  exampleReading  String?
  exampleMeaning  String?
  orderIndex      Int    @default(0)
}

model UserProgress {
  id            String   @id @default(cuid())
  userId        String
  contentType   String   // kana, word, grammar
  contentId     String
  status        String   @default("new") // new, learning, mastered
  correctCount  Int      @default(0)
  incorrectCount Int     @default(0)
  lastReviewedAt DateTime?
  nextReviewAt   DateTime?
  easeFactor    Float    @default(2.5)
  interval      Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, contentType, contentId])
  @@index([userId])
  @@index([userId, nextReviewAt])
}

model QuizAttempt {
  id             String   @id @default(cuid())
  userId         String
  quizType       String   // kana, word
  questionData   String   // JSON string
  selectedAnswer String
  correctAnswer  String
  isCorrect      Boolean
  timeSpent      Int      @default(0)
  createdAt      DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
}

model Bookmark {
  id          String   @id @default(cuid())
  userId      String
  contentType String
  contentId   String
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, contentType, contentId])
  @@index([userId])
}

model EmailVerificationCode {
  id        String   @id @default(cuid())
  email     String
  code      String   // 6-digit code (hashed)
  attempts  Int      @default(0)
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([email])
  @@index([expiresAt])
}

model RateLimit {
  id        String   @id @default(cuid())
  key       String   @unique // e.g. "login:1.2.3.4" or "send-code:user@example.com"
  count     Int      @default(1)
  windowEnd DateTime // when the current window expires; older windows are cleaned up
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([windowEnd])
}
